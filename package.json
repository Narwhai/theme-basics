    "obsidian",
    "obsidian-plugin",
    "theme"
  ],
  "author": "Dev-Vault",
  "license": "UNLICENSED",
  "dependencies": {
    "obsidian": "latest"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^16.4.0",
    "jiti": "^2.6.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1"
  }
}
