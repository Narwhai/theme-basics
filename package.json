{
  "name": "theme-basics",
  "version": "1.1.0",
  "description": "Appearance customization without CSS snippets. Modify colors, text sizing/spacing, and more.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint ."
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "theme"
  ],
  "author": "Dev-Vault",
  "license": "MIT",
  "devDependencies": {
