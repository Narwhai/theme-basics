{
  "name": "theme-basics",
  "version": "0.2.0",
  "description": "Customize the appearance of Obsidian without plugins. Modify colors, text sizing/spacing, and more",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint ."
  },
